# Base URL of the Hackplate API. Defaults to http://localhost:8000 (the
# uvicorn dev server) when unset. The backend allows CORS for the Vite dev
# origin (http://localhost:5173) with credentials, and the Auth0 plate
# authenticates via httpOnly cookies — both origins are the same site, so the
# session cookie rides along on cross-origin requests.
VITE_API_BASE_URL=http://localhost:8000
